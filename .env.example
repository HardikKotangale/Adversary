# Adversary — root environment file, used by docker-compose (and referenced
# by backend/.env.example + frontend/.env.example for non-Docker local dev).
# Copy this to .env and fill in your credentials before running
# `docker compose up` or `./deploy.sh`.

# ---- Server ---------------------------------------------------------------
PORT=4000
CORS_ORIGIN=http://localhost:3000

# ---- Qwen Cloud (Alibaba DashScope, OpenAI-compatible endpoint) -----------
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_PERSONA_MODEL=qwen3.7-plus
QWEN_MEDIATOR_MODEL=qwen3.7-max

# ---- Alibaba Cloud RDS for PostgreSQL --------------------------------------
# Leave RDS_HOST empty to run against an in-memory store instead (fine for
# local dev/demos; debates won't survive a restart).
RDS_HOST=
RDS_PORT=5432
RDS_USER=
RDS_PASSWORD=
RDS_DATABASE=adversary
RDS_SSL=true

# ---- Alibaba Cloud OSS (Object Storage Service) ----------------------------
# Leave ALIBABA_ACCESS_KEY_ID empty to fall back to writing transcripts to
# local disk instead (backend/data/transcripts/).
ALIBABA_ACCESS_KEY_ID=
ALIBABA_ACCESS_KEY_SECRET=
OSS_REGION=oss-us-east-1
OSS_BUCKET=

# ---- Frontend ---------------------------------------------------------------
# Leave empty for the Docker/nginx deployment (same-origin /api proxying).
# Set to e.g. http://localhost:4000 for non-Docker local dev.
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_USE_MOCK=false
