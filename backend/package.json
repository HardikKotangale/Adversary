{
  "name": "adversary-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && cp src/schema.sql dist/schema.sql",
    "start": "node dist/index.js",
    "migrate": "tsx src/migrate.ts",
    "migrate:built": "node dist/migrate.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ali-oss": "^6.20.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "openai": "^4.68.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/ali-oss": "^6.16.11",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4"
  }
}
